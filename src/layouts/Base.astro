---
import '../styles/app.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const { title, description, page = 'home' } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#051D1D" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={base + 'brand_assets/favicon.svg'} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>

<body class="bg-white text-valo-ink">

  <a href="#main" class="skip-link">Skip to content</a>

  <Nav page={page} />

  <main id="main">
    <slot />
  </main>

  <Footer page={page} />

  <script is:inline src={base + 'vendor/gsap/gsap.min.js'}></script>
  <script is:inline src={base + 'vendor/gsap/ScrollTrigger.min.js'}></script>
  <script is:inline>
    // Tubelight nav: one shared lamp element springs to the selected link.
    (function () {
      var wrap = document.getElementById('nav-links');
      var lamp = document.getElementById('nav-lamp');
      if (!wrap || !lamp) return;
      var links = Array.prototype.slice.call(wrap.querySelectorAll('.nav-link'));
      if (!links.length) return;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var PAD = 12; // pill extends a little beyond the label
      var active = wrap.querySelector('.nav-link.is-current') || links[0];

      function place(link, animate) {
        var x = link.offsetLeft - PAD;
        var w = link.offsetWidth + PAD * 2;
        links.forEach(function (l) { l.classList.toggle('lamp-active', l === link); });
        if (window.gsap && !reduced && animate) {
          gsap.to(lamp, { x: x, width: w, opacity: 1, duration: .55, ease: 'back.out(1.7)' });
        } else {
          if (window.gsap) gsap.set(lamp, { x: x, width: w, opacity: 1 });
          else {
            lamp.style.transform = 'translateX(' + x + 'px)';
            lamp.style.width = w + 'px';
            lamp.style.opacity = '1';
          }
        }
        active = link;
      }

      links.forEach(function (l) {
        l.addEventListener('click', function () { place(l, true); });
      });
      window.addEventListener('resize', function () { place(active, false); });
      // Reposition once fonts have loaded so label widths are final
      window.addEventListener('load', function () { place(active, false); });
      place(active, false);
    })();
  </script>
  <slot name="scripts" />
</body>
</html>
