---
import '../styles/app.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const { title, description, page = 'home' } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#051D1D" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={base + 'brand_assets/favicon.svg'} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>

<body class="bg-white text-valo-ink">

  <a href="#main" class="skip-link">Skip to content</a>

  <Nav page={page} />

  <main id="main">
    <slot />
  </main>

  <Footer page={page} />

  <script is:inline src={base + 'vendor/gsap/gsap.min.js'}></script>
  <script is:inline src={base + 'vendor/gsap/ScrollTrigger.min.js'}></script>
  <slot name="scripts" />
</body>
</html>
