---
import Base from '../layouts/Base.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<Base
  title="About Valo | Software for the work that matters most"
  description="Valo exists for the organisations that hold funds on behalf of others and turn them into real outcomes for real people. Meet the team and the principles we build by."
  page="about"
>

  <!-- ================= HERO ================= -->
  <section class="hero-bg relative overflow-hidden">
    <div class="grain"></div>
    <div class="glow-orb" id="orb-1" style="width:520px;height:520px;top:-16%;right:-6%;background:rgba(2,148,145,.32);"></div>

    <div class="relative mx-auto max-w-7xl px-5 sm:px-8 pt-36 pb-20 lg:pt-44 lg:pb-24">
      <div class="max-w-3xl">
        <p class="eyebrow text-valo-300 mb-6 flex items-center gap-3" data-fade><span class="inline-block w-5 h-px" style="background:#54DB98;"></span>About Valo</p>
        <h1 class="font-display font-extrabold text-white leading-[1.08] text-4xl sm:text-5xl lg:text-6xl" data-fade>
          Software for the work that <span class="text-gradient">matters most</span>
        </h1>
        <p class="body-copy mt-7 max-w-2xl text-lg" style="color: rgba(232,241,239,.78);" data-fade>
          Valo exists for the organisations that hold funds on behalf of others and turn them into real outcomes for real people. We bring identity, payments, data and reporting together in one trusted platform, so the people doing this work can spend less time fighting systems and more time making a difference.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-4" data-fade>
          <a href="mailto:hello@valo.io" class="btn btn-primary">
            Get in touch
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href={base + 'index.html#products'} class="btn btn-ghost-dark">Explore the platform</a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 inset-x-0 h-16" style="background: linear-gradient(to bottom, rgba(255,255,255,0), #fff);"></div>
  </section>

  <!-- ================= WHY WE EXIST ================= -->
  <section class="relative py-20 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <div class="lg:col-span-6" data-reveal>
          <p class="eyebrow text-valo-600 mb-4 flex items-center gap-3"><span class="inline-block w-5 h-px" style="background:#029491;"></span>Why we exist</p>
          <h2 class="font-display font-extrabold text-3xl sm:text-[2.4rem] leading-[1.12]">The systems that hold trust were never built for it</h2>
          <p class="body-copy mt-5 text-lg text-neutral-600">Organisations that manage funds for others have been stitching together spreadsheets, finance tools and case systems that were never designed to talk to each other. The result is duplicated effort, slow reporting and money that is hard to trace back to the people it was meant for.</p>
          <p class="body-copy text-lg text-neutral-600 mt-5">We started Valo to fix that. One platform where identity, money, data and outcomes finally live together, built specifically for the high-trust, high-accountability world of social investment.</p>
        </div>
        <div class="lg:col-span-6" data-reveal>
          <div class="codecard" id="codecard">
            <div class="cc-bar">
              <span class="cc-dots"><i></i><i></i><i></i></span>
              <span class="cc-title">what we bring together</span>
            </div>
            <div class="p-6 grid gap-4">
              <div class="flex items-center gap-3" data-cc-row>
                <span class="cc-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M12 6h.01M16 6h.01M8 10h.01M12 10h.01M16 10h.01"/></svg></span>
                <span><span class="block text-white font-bold">Identity &amp; records</span><span class="block text-sm" style="color: rgba(232,241,239,.6);">One trusted profile, under your brand</span></span>
              </div>
              <div class="flex items-center gap-3" data-cc-row>
                <span class="cc-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></span>
                <span><span class="block text-white font-bold">Money &amp; budgets</span><span class="block text-sm" style="color: rgba(232,241,239,.6);">Every dollar traceable to a person</span></span>
              </div>
              <div class="flex items-center gap-3" data-cc-row>
                <span class="cc-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg></span>
                <span><span class="block text-white font-bold">Data &amp; insight</span><span class="block text-sm" style="color: rgba(232,241,239,.6);">Connected, secure, always current</span></span>
              </div>
              <div class="flex items-center gap-3" data-cc-row>
                <span class="cc-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></span>
                <span><span class="block text-white font-bold">Outcomes</span><span class="block text-sm" style="color: rgba(232,241,239,.6);">Proof of the difference you make</span></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= PRINCIPLES ================= -->
  <section class="relative py-20 lg:py-24 bg-neutral-50" style="border-top: 1px solid #EDF1F1; border-bottom: 1px solid #EDF1F1;">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow text-valo-600 mb-4 flex items-center gap-3"><span class="inline-block w-5 h-px" style="background:#029491;"></span>What we believe</p>
        <h2 class="font-display font-extrabold text-3xl sm:text-[2.4rem] leading-[1.12]">The principles we build by</h2>
        <p class="body-copy mt-5 text-lg text-neutral-600">These are the ideas that shape every product decision we make, from the smallest setting to the shape of the whole platform.</p>
      </div>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5" id="principle-grid">
        <div class="value-card" data-reveal>
          <span class="icon-tile"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1Z"/></svg></span>
          <h3 class="font-display font-bold text-lg mt-4">Trust is the whole job</h3>
          <p class="body-copy text-[.9375rem] text-neutral-600 mt-2.5">Not bolted on afterwards. The controls that protect your funds and your data are part of the platform itself.</p>
        </div>
        <div class="value-card" data-reveal>
          <span class="icon-tile"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
          <h3 class="font-display font-bold text-lg mt-4">People before process</h3>
          <p class="body-copy text-[.9375rem] text-neutral-600 mt-2.5">Behind every payment and every record is a person being supported. We build for the coordinators, carers and finance teams who make that support real.</p>
        </div>
        <div class="value-card" data-reveal>
          <span class="icon-tile"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m7 14 4-4 4 4 5-6"/></svg></span>
          <h3 class="font-display font-bold text-lg mt-4">Outcomes, not just outputs</h3>
          <p class="body-copy text-[.9375rem] text-neutral-600 mt-2.5">It is not enough to move money. We help organisations show the difference that money made, so good work can be seen, funded and repeated.</p>
        </div>
        <div class="value-card" data-reveal>
          <span class="icon-tile"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg></span>
          <h3 class="font-display font-bold text-lg mt-4">Open by default</h3>
          <p class="body-copy text-[.9375rem] text-neutral-600 mt-2.5">The product and the platform are the same thing. That means no feature is ever locked away from your own systems.</p>
        </div>
        <div class="value-card" data-reveal>
          <span class="icon-tile"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/></svg></span>
          <h3 class="font-display font-bold text-lg mt-4">Configurable, not rigid</h3>
          <p class="body-copy text-[.9375rem] text-neutral-600 mt-2.5">No two organisations work the same way. Valo bends to fit how you actually operate, instead of forcing you to change to suit the software.</p>
        </div>
        <div class="value-card" data-reveal>
          <span class="icon-tile"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12.5 11.17 16.66a2 2 0 0 0 1.66 0L22 12.5"/><path d="M2 17 11.17 21.16a2 2 0 0 0 1.66 0L22 17"/><path d="m2 8 9.17 4.16a2 2 0 0 0 1.66 0L22 8l-9.17-4.16a2 2 0 0 0-1.66 0Z"/></svg></span>
          <h3 class="font-display font-bold text-lg mt-4">Built to last</h3>
          <p class="body-copy text-[.9375rem] text-neutral-600 mt-2.5">Cloud-native, secure and always improving. We are building infrastructure that organisations can rely on for the long haul.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= TEAM ================= -->
  <section class="relative py-20 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow text-valo-600 mb-4 flex items-center gap-3"><span class="inline-block w-5 h-px" style="background:#029491;"></span>The people behind Valo</p>
        <h2 class="font-display font-extrabold text-3xl sm:text-[2.4rem] leading-[1.12]">A senior, kind team</h2>
        <p class="body-copy mt-5 text-lg text-neutral-600">The people leading Valo, from technology and the social sector to the highest levels of public finance.</p>
      </div>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5" id="team-grid">
        <div class="team-card" data-reveal>
          <div class="team-photo"><img src={base + 'brand_assets/team-ben-irving.jpg'} alt="Ben Irving, Chief Executive" /></div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl">Ben Irving</h3>
            <p class="font-mono text-xs text-valo-700 mt-1 uppercase tracking-[.08em]">Chief Executive</p>
            <p class="body-copy text-[.9375rem] text-neutral-600 mt-3">Leads Valo and its mission. Ben brings years across technology and the social sector, and keeps the whole team focused on the people every fund is meant to serve.</p>
          </div>
        </div>
        <div class="team-card" data-reveal>
          <div class="team-photo"><img src={base + 'brand_assets/team-louis-goodier.jpg'} alt="Louis Goodier, Chief Technology Officer" /></div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl">Louis Goodier</h3>
            <p class="font-mono text-xs text-valo-700 mt-1 uppercase tracking-[.08em]">Chief Technology Officer</p>
            <p class="body-copy text-[.9375rem] text-neutral-600 mt-3">Owns the platform and the engineering behind it. Louis builds the secure, cloud-native foundations Valo runs on, and believes good infrastructure should be invisible and unbreakable.</p>
          </div>
        </div>
        <div class="team-card" data-reveal>
          <div class="team-photo"><img src={base + 'brand_assets/team-bill-english.jpg'} alt="Sir Bill English, Director" /></div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl">Sir Bill English</h3>
            <p class="font-mono text-xs text-valo-700 mt-1 uppercase tracking-[.08em]">Director</p>
            <p class="body-copy text-[.9375rem] text-neutral-600 mt-3">A former Prime Minister and Minister of Finance of New Zealand who helped pioneer the social investment approach in government.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= JOIN / CONTACT ================= -->
  <section class="relative py-20 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="relative overflow-hidden rounded-3xl px-8 py-16 sm:px-16 sm:py-20 text-center hero-bg" data-reveal>
        <div class="grain"></div>
        <div class="glow-orb" style="width:460px;height:460px;top:-40%;left:50%;margin-left:-230px;background:rgba(84,219,152,.25);"></div>
        <div class="relative">
          <img src={base + 'brand_assets/mark-white.svg'} alt="" class="h-10 w-10 mx-auto mb-7 opacity-90" />
          <h2 class="font-display font-extrabold text-white text-3xl sm:text-[2.75rem] leading-[1.1] max-w-2xl mx-auto">Help us build software for the work that matters</h2>
          <p class="body-copy mt-5 text-lg max-w-xl mx-auto" style="color: rgba(232,241,239,.75);">We are a small team taking on a big mission, and we are growing. If you care about doing meaningful work with money, data and outcomes, we would love to hear from you, even if there is no role listed yet.</p>
          <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
            <a href="mailto:hello@valo.io" class="btn btn-primary">Say hello</a>
            <a href="mailto:careers@valo.io" class="btn btn-ghost-dark">careers@valo.io</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="scripts">
    <script is:inline>
    (function () {
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var hasGsap = !!window.gsap && !reduced;

      /* ---------- Mobile nav ---------- */
      var burger = document.getElementById('nav-burger');
      var mobileMenu = document.getElementById('mobile-menu');
      var burgerOpen = document.getElementById('burger-open');
      var burgerClose = document.getElementById('burger-close');
      function setMenu(open) {
        mobileMenu.hidden = !open;
        burger.setAttribute('aria-expanded', open ? 'true' : 'false');
        burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        burgerOpen.classList.toggle('hidden', open);
        burgerClose.classList.toggle('hidden', !open);
        if (open && hasGsap) {
          gsap.fromTo(mobileMenu.children,
            { opacity: 0, y: -8 },
            { opacity: 1, y: 0, duration: .35, ease: 'power2.out', stagger: .04 });
        }
      }
      burger.addEventListener('click', function () { setMenu(mobileMenu.hidden); });
      mobileMenu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { setMenu(false); });
      });

      if (!hasGsap) return;
      gsap.registerPlugin(ScrollTrigger);
      // Mobile browsers resize the viewport when the URL bar hides/shows;
      // without this every ScrollTrigger recalculates mid-scroll and jumps.
      ScrollTrigger.config({ ignoreMobileResize: true });
      document.documentElement.classList.add('gs-ready');

      var expo = 'expo.out';

      // Load-in
      var tl = gsap.timeline({ defaults: { ease: expo } });
      tl.to('#site-nav', { opacity: 1, duration: .8 }, 0)
        .to('[data-fade]', { opacity: 1, duration: .9, stagger: .14 }, .15);

      // Ambient orb (desktop only; the orb is hidden on mobile for performance)
      if (window.innerWidth >= 768) {
        gsap.to('#orb-1', { x: -50, y: 50, duration: 15, ease: 'sine.inOut', repeat: -1, yoyo: true });
      }

      // Code-card rows cascade in as the card reveals
      gsap.fromTo('#codecard [data-cc-row]',
        { opacity: 0, x: -16 },
        {
          opacity: 1, x: 0, duration: .55, ease: 'expo.out', stagger: .12,
          scrollTrigger: { trigger: '#codecard', start: 'top 78%', once: true },
        });

      // Scroll reveals: grids stagger, everything else individually
      var groups = ['#principle-grid', '#team-grid'];
      groups.forEach(function (sel) {
        var items = document.querySelectorAll(sel + ' > [data-reveal]');
        gsap.to(items, {
          opacity: 1, y: 0, duration: .9, ease: expo, stagger: .09,
          scrollTrigger: { trigger: sel, start: 'top 78%', once: true },
        });
      });
      document.querySelectorAll('[data-reveal]').forEach(function (el) {
        if (el.parentElement && groups.indexOf('#' + el.parentElement.id) !== -1) return;
        gsap.to(el, {
          opacity: 1, y: 0, duration: 1, ease: expo,
          scrollTrigger: { trigger: el, start: 'top 82%', once: true },
        });
      });
    })();
    </script>
  </Fragment>
</Base>

<style is:global>
  /* Terminal-style card from valo.io/about ("what we bring together") */
  .codecard {
    background: #051D1D; border: 1px solid rgba(255,255,255,.12);
    border-radius: 20px; overflow: hidden;
    box-shadow: 0 24px 60px -24px rgba(5,29,29,.55);
  }
  .cc-bar {
    display: flex; align-items: center; gap: .75rem;
    padding: 13px 1.25rem; border-bottom: 1px solid rgba(255,255,255,.1);
  }
  .cc-dots { display: flex; gap: 6px; }
  .cc-dots i { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,.18); }
  .cc-title { font-family: "JetBrains Mono", monospace; font-size: .75rem; color: rgba(232,241,239,.6); }
  .cc-ico {
    width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(84,219,152,.14); color: #54DB98;
  }

  .team-card {
    background: #fff; border: 1px solid #DCE3E3; border-radius: 20px; overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform .25s cubic-bezier(.34,1.56,.64,1), border-color .25s ease;
    will-change: transform;
  }
  .team-card:hover { transform: translateY(-4px) scale(1.02); border-color: #A6E9C6; }
  .team-photo { position: relative; aspect-ratio: 4 / 3.4; overflow: hidden; }
  .team-photo img { width: 100%; height: 100%; object-fit: cover; }
  .team-photo::before {
    content: ""; position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(to top, rgba(5,29,29,.55), transparent 55%);
  }
  .team-photo::after {
    content: ""; position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(135deg, rgba(2,148,145,.28), rgba(84,219,152,.12));
    mix-blend-mode: multiply;
  }
</style>
